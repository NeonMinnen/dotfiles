Xcursor.size: 16
Xft.dpi: 96
Xft.hinting: 1
Xft.hintstyle: hintslight
Xft.antialias: 1
Xft.rgba: rgb
Xft.lcdfilter: lcddefault
*.font:	JetBrains Mono:pixelsize=16:antialias=true:autohint=true;

! Alacritty Color Scheme in .Xresources format

! Primary colors
*foreground:   #ECE1D7
*background:   #292522

! Normal colors
*color0:       #34302C
*color1:       #BD8183
*color2:       #78997A
*color3:       #E49B5D
*color4:       #7F91B2
*color5:       #B380B0
*color6:       #7B9695
*color7:       #C1A78E

! Bright colors
*color8:       #867462
*color9:       #D47766
*color10:      #85B695
*color11:      #E49B5D
*color12:      #A3A9CE
*color13:      #CF9BC2
*color14:      #89B3B6
*color15:      #ECE1D7

