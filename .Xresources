Xcursor.size: 16
Xft.dpi: 109
Xft.hinting: 1
Xft.hintstyle: hintslight
Xft.antialias: 1
Xft.rgba: rgb
Xft.lcdfilter: lcddefault

! X colors.
! Generated by 'wal'
*foreground:        #dfebef
*background:        #011407
*.foreground:       #dfebef
*.background:       #011407
emacs*foreground:   #dfebef
emacs*background:   #011407
URxvt*foreground:   #dfebef
XTerm*foreground:   #dfebef
UXTerm*foreground:  #dfebef
URxvt*background:   [100]#011407
XTerm*background:   #011407
UXTerm*background:  #011407
URxvt*cursorColor:  #dfebef
XTerm*cursorColor:  #dfebef
UXTerm*cursorColor: #dfebef
URxvt*borderColor:  [100]#011407

! Colors 0-15.
*.color0: #011407
*color0:  #011407
*.color1: #3E8677
*color1:  #3E8677
*.color2: #707591
*color2:  #707591
*.color3: #4E9F9A
*color3:  #4E9F9A
*.color4: #5DA29A
*color4:  #5DA29A
*.color5: #95B3BE
*color5:  #95B3BE
*.color6: #A2D3D6
*color6:  #A2D3D6
*.color7: #dfebef
*color7:  #dfebef
*.color8: #9ca4a7
*color8:  #9ca4a7
*.color9: #3E8677
*color9:  #3E8677
*.color10: #707591
*color10:  #707591
*.color11: #4E9F9A
*color11:  #4E9F9A
*.color12: #5DA29A
*color12:  #5DA29A
*.color13: #95B3BE
*color13:  #95B3BE
*.color14: #A2D3D6
*color14:  #A2D3D6
*.color15: #dfebef
*color15:  #dfebef

! Black color that will not be affected by bold highlighting.
*.color66: #011407
*color66:  #011407

! Xclock colors.
XClock*foreground: #dfebef
XClock*background: #011407
XClock*majorColor:  rgba:df/eb/ef/ff
XClock*minorColor:  rgba:df/eb/ef/ff
XClock*hourColor:   rgba:df/eb/ef/ff
XClock*minuteColor: rgba:df/eb/ef/ff
XClock*secondColor: rgba:df/eb/ef/ff

! Set depth to make transparency work.
URxvt*depth: 32
